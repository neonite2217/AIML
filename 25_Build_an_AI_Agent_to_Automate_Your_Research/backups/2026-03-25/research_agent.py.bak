# You may need to install these packages first:
# pip install beautifulsoup4 requests sentence-transformers torch
from bs4 import BeautifulSoup
import requests
from sentence_transformers import SentenceTransformer, util
import torch

# 1. Search web for query (mocked for this example)
def search_web(query):
    print(f"Mocking web search for: '{query}'")
    # In a real scenario, you would use a search API like DuckDuckGoSearchRun from langchain
    return [
        "https://en.wikipedia.org/wiki/Transformer_(machine_learning_model)",
        "https://huggingface.co/docs/transformers/index"
    ]

# 2. Fetch and clean HTML text
def fetch_and_clean(url):
    try:
        # Some websites block requests without a user-agent
        headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/58.0.3029.110 Safari/537.3'}
        response = requests.get(url, headers=headers, timeout=10)
        response.raise_for_status() # Raise an exception for bad status codes
        soup = BeautifulSoup(response.text, 'html.parser')
        # Remove script and style elements
        for script in soup(["script", "style"]):
            script.extract()
        return soup.get_text(separator=' ', strip=True)
    except Exception as e:
        print(f"Failed to fetch {url}: {e}")
        return ""

# 3. Chunk content and embed
def chunk_text(text, chunk_size=1000, chunk_overlap=200):
    # Simple sliding window chunking
    return [text[i:i+chunk_size] for i in range(0, len(text), chunk_size - chunk_overlap)]

embedding_model = SentenceTransformer('all-MiniLM-L6-v2')

query = "What is a Transformer model in machine learning?"
urls = search_web(query)
all_chunks = []
for url in urls:
    content = fetch_and_clean(url)
    if content:
        all_chunks.extend(chunk_text(content))

if all_chunks:
    chunk_embeddings = embedding_model.encode(all_chunks, convert_to_tensor=True)

    # 4. Embed query and score chunk similarity
    query_embedding = embedding_model.encode(query, convert_to_tensor=True)
    cosine_scores = util.pytorch_cos_sim(query_embedding, chunk_embeddings)[0]

    # 5. Select top passages
    top_k = 3
    top_results = torch.topk(cosine_scores, k=min(top_k, len(all_chunks)))
    top_passages = [all_chunks[i] for i in top_results.indices]

    # 6. Summarize (simplified for demo)
    summary = "\n\n".join(top_passages)
    print("\n--- Top Relevant Passages ---")
    print(summary)

    # A real implementation would use a summarization model here.
    print("\n--- Final Summarized Answer (Placeholder) ---")
    print(f"Based on the research, a Transformer model is a key architecture in machine learning, heavily used in NLP. The retrieved passages discuss its components and applications, particularly attention mechanisms. (A real summary would be more concise).")

else:
    print("Could not retrieve any content to process.")
