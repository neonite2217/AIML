# Environment Variables Template
# Copy this file to .env and update values as needed
# DO NOT commit .env to version control

# Airflow Configuration
AIRFLOW_HOME=/var/home/ansh/Projects/super_30/16_MLOps_Pipeline_using_Apache_Airflow/airflow_home
AIRFLOW__CORE__DAGS_FOLDER=/var/home/ansh/Projects/super_30/16_MLOps_Pipeline_using_Apache_Airflow/dags

# Database Configuration (SQLite - default for local dev)
# For production, use PostgreSQL
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///${AIRFLOW_HOME}/airflow.db

# Executor Configuration
# SequentialExecutor for local development
# CeleryExecutor or KubernetesExecutor for production
AIRFLOW__CORE__EXECUTOR=SequentialExecutor

# Logging
AIRFLOW__LOGGING__BASE_LOG_FOLDER=${AIRFLOW_HOME}/logs
AIRFLOW__LOGGING__DAG_PROCESSOR_MANAGER_LOG_LOCATION=${AIRFLOW_HOME}/logs/dag_processor_manager/dag_processor_manager.log

# Webserver
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080

# Security (change in production!)
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here-change-in-production

# Email (optional - for notifications)
# AIRFLOW__EMAIL__EMAIL_BACKEND=airflow.utils.email.send_email_smtp
# AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
# AIRFLOW__SMTP__SMTP_PORT=587
# AIRFLOW__SMTP__SMTP_USER=your-email@gmail.com
# AIRFLOW__SMTP__SMTP_PASSWORD=your-app-password

# Note: Replace the paths above with your actual project path
# Example: /home/user/projects/mlops-pipeline
